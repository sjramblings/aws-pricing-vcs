# VCS (Viking Context Service) credentials
VCS_API_URL=https://vcs.example.com
VCS_API_KEY=your-vcs-api-key

# AWS Pricing API — the Pricing API is only available in us-east-1 and ap-south-1
AWS_REGION=us-east-1
# Credentials resolved via default provider chain (env, profile, IMDS, etc.)
# AWS_PROFILE=default
